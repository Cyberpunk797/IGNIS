{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axlu-zesi-cp.local/problem_bank.schema.json",
  "title": "ProblemBankEntry",
  "type": "object",
  "required": [
    "problem_id",
    "title",
    "difficulty_rating",
    "bucket",
    "tags",
    "planned_tasks",
    "status",
    "concept_pitch"
  ],
  "properties": {
    "problem_id": {"type": "string"},
    "title": {"type": "string"},
    "difficulty_rating": {"type": "integer"},
    "bucket": {"type": "string", "enum": ["fast", "medium", "high"]},
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "planned_tasks": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "status": {"type": "string", "enum": ["planned", "detailed"]},
    "concept_pitch": {"type": "string"}
  }
}
